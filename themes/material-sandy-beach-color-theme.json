{
  "name": "Material Sandy Beach",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#FFF8ED",
    "editor.foreground": "#546E7A",
    "editor.selectionBackground": "#E7C496",
    "editor.lineHighlightBackground": "#ECF0F1",
    "editorCursor.foreground": "#272727",
    "editorWhitespace.foreground": "#E7EAEC",
    "editorLineNumber.foreground": "#888477",
    "editorLineNumber.activeForeground": "#888477",
    "editorIndentGuide.background": "#B8B6A5",
    "editorIndentGuide.activeBackground": "#53C7F0",
    "tab.activeBackground": "#FFF8ED",
    "tab.activeForeground": "#272727",
    "tab.inactiveBackground": "#F6EDDA",
    "tab.inactiveForeground": "#888477",
    "tab.activeBorder": "#53C7F0",
    "tab.border": "#E8DEC8",
    "tab.hoverBackground": "#FFF8ED",
    "editorGroupHeader.tabsBackground": "#F6EDDA",
    "editorGroupHeader.tabsBorder": "#E8DEC8",
    "editorGroupHeader.noTabsBackground": "#F6EDDA",
    "sideBar.background": "#F6EDDA",
    "sideBar.foreground": "#546E7A",
    "activityBar.background": "#E9E2D8",
    "activityBar.foreground": "#546E7A",
    "activityBar.border": "#D4C4A8",
    "activityBar.activeBorder": "#39ADB5",
    "activityBarBadge.background": "#39ADB5",
    "titleBar.activeBackground": "#E9E2D8",
    "titleBar.activeForeground": "#546E7A",
    "titleBar.inactiveBackground": "#EDE6DC",
    "titleBar.inactiveForeground": "#888477",
    "titleBar.border": "#D4C4A8",
    "statusBar.background": "#F6EDDA",
    "statusBar.foreground": "#546E7A",
    "statusBar.noFolderBackground": "#39ADB5",
    "statusBar.noFolderForeground": "#FFFFFF",
    "terminal.background": "#FFF8ED",
    "terminal.foreground": "#546E7A",
    "terminal.ansiBlack": "#272727",
    "terminal.ansiRed": "#F76D47",
    "terminal.ansiGreen": "#91B859",
    "terminal.ansiYellow": "#E2931D",
    "terminal.ansiBlue": "#6182B8",
    "terminal.ansiMagenta": "#945EB8",
    "terminal.ansiCyan": "#39ADB5",
    "terminal.ansiWhite": "#F8F8F0",
    "list.activeSelectionBackground": "#E7C496",
    "list.activeSelectionForeground": "#272727",
    "list.inactiveSelectionBackground": "#F6D7B0",
    "list.hoverBackground": "#FEF8EC",
    "scrollbarSlider.background": "#53C7F080",
    "scrollbarSlider.hoverBackground": "#53C7F0",
    "scrollbarSlider.activeBackground": "#53C7F0",

    "editorHoverWidget.background": "#FFF8ED",
    "editorHoverWidget.border": "#D4C4A8",
    "editorHoverWidget.foreground": "#546E7A",
    "editorHoverWidget.highlightForeground": "#39ADB5",
    "editorHoverWidget.statusBarBackground": "#F6EDDA",

    "editorSuggestWidget.background": "#FFF8ED",
    "editorSuggestWidget.border": "#D4C4A8",
    "editorSuggestWidget.foreground": "#546E7A",
    "editorSuggestWidget.highlightForeground": "#39ADB5",
    "editorSuggestWidget.focusHighlightForeground": "#39ADB5",
    "editorSuggestWidget.selectedBackground": "#E7C496",
    "editorSuggestWidget.selectedForeground": "#272727",
    "editorSuggestWidget.selectedIconForeground": "#272727",

    "editorWidget.background": "#FFF8ED",
    "editorWidget.border": "#D4C4A8",
    "editorWidget.foreground": "#546E7A",
    "editorWidget.resizeBorder": "#53C7F0",

    "peekView.border": "#D4C4A8",
    "peekViewEditor.background": "#FFF8ED",
    "peekViewEditor.matchHighlightBackground": "#E7C49680",
    "peekViewResult.background": "#F6EDDA",
    "peekViewResult.fileForeground": "#546E7A",
    "peekViewResult.lineForeground": "#888477",
    "peekViewResult.matchHighlightBackground": "#E7C49680",
    "peekViewResult.selectionBackground": "#E7C496",
    "peekViewResult.selectionForeground": "#272727",
    "peekViewTitle.background": "#F6EDDA",
    "peekViewTitleDescription.foreground": "#888477",
    "peekViewTitleLabel.foreground": "#546E7A",

    "notifications.background": "#FFF8ED",
    "notifications.border": "#D4C4A8",
    "notifications.foreground": "#546E7A",
    "notificationLink.foreground": "#39ADB5",
    "notificationsErrorIcon.foreground": "#F76D47",
    "notificationsWarningIcon.foreground": "#E2931D",
    "notificationsInfoIcon.foreground": "#39ADB5",

    "debugExceptionWidget.background": "#FFF8ED",
    "debugExceptionWidget.border": "#D4C4A8",

    "editorMarkerNavigation.background": "#FFF8ED",
    "editorMarkerNavigationError.background": "#F76D4720",
    "editorMarkerNavigationWarning.background": "#E2931D20",
    "editorMarkerNavigationInfo.background": "#39ADB520",

    "button.background": "#39ADB5",
    "button.foreground": "#FFFFFF",
    "button.hoverBackground": "#2E9AA1"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#888477",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#945EB8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.control.import.python",
        "keyword.control.from.python",
        "keyword.control.as.python",
        "keyword.control.flow.python",
        "keyword.control.conditional.python",
        "keyword.control.loop.python",
        "keyword.control.exception.python",
        "keyword.control.return.python",
        "keyword.control.async.python",
        "keyword.control.await.python",
        "keyword.operator.logical.python",
        "keyword.operator.wordlike.python",
        "keyword.operator.expression.is.python",
        "keyword.operator.expression.not.python"
      ],
      "settings": {
        "foreground": "#39ADB5",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.argument.python",
        "variable.parameter.function-call.python",
        "meta.function-call.arguments.python variable.parameter.python",
        "meta.function-call.python variable.parameter.python"
      ],
      "settings": {
        "foreground": "#945EB8"
      }
    },
    {
      "scope": [
        "string",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#91B859"
      }
    },
    {
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#F76D47"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#6182B8"
      }
    },
    {
      "scope": [
        "entity.name.class",
        "entity.name.type",
        "support.class",
        "support.type",
        "support.type.exception.python",
        "support.class.exception.python",
        "meta.typehint.python support.class",
        "meta.typehint.python support.type",
        "meta.annotation.python support.class",
        "meta.annotation.python support.type"
      ],
      "settings": {
        "foreground": "#E2931D"
      }
    },
    {
      "scope": "variable",
      "settings": {
        "foreground": "#272727"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "entity.name.variable.parameter"
      ],
      "settings": {
        "foreground": "#F76D47"
      }
    },
    {
      "scope": [
        "variable.language.special.self.python",
        "variable.parameter.function.language.special.self.python",
        "variable.language.special.cls.python"
      ],
      "settings": {
        "foreground": "#E53935",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation"
      ],
      "settings": {
        "foreground": "#39ADB5"
      }
    },
    {
      "scope": "entity.name.tag",
      "settings": {
        "foreground": "#E53935"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#F76D47"
      }
    },
    {
      "scope": [
        "support.function",
        "support.function.builtin",
        "support.function.magic.python",
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#6182B8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "support.constant",
      "settings": {
        "foreground": "#F76D47"
      }
    },

    {
      "scope": [
        "markup.heading.1.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#C77A1A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "entity.name.section.markdown",
      "settings": {
        "foreground": "#C77A1A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.heading.2.markdown",
      "settings": {
        "foreground": "#E2931D",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.heading.3.markdown",
      "settings": {
        "foreground": "#F7A84A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.heading.4.markdown",
        "markup.heading.5.markdown",
        "markup.heading.6.markdown"
      ],
      "settings": {
        "foreground": "#F76D47",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.bold.markdown",
      "settings": {
        "foreground": "#272727",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.italic.markdown",
      "settings": {
        "foreground": "#E2931D",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "markup.bold_italic.markdown",
      "settings": {
        "foreground": "#C77A1A",
        "fontStyle": "bold italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw.string.markdown",
        "markup.raw.inline.markdown"
      ],
      "settings": {
        "foreground": "#F76D47"
      }
    },
    {
      "scope": "fenced_code.block.language.markdown",
      "settings": {
        "foreground": "#888477",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "beginning.punctuation.definition.list.markdown"
      ],
      "settings": {
        "foreground": "#39ADB5",
        "fontStyle": "bold"
      }
    },
    {
      "scope": "markup.list.unnumbered.markdown",
      "settings": {
        "foreground": "#6E8796"
      }
    },
    {
      "scope": "markup.list.numbered.markdown",
      "settings": {
        "foreground": "#6E8796"
      }
    },
    {
      "scope": "string.other.link.title.markdown",
      "settings": {
        "foreground": "#6182B8"
      }
    },
    {
      "scope": [
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown"
      ],
      "settings": {
        "foreground": "#39ADB5"
      }
    },
    {
      "scope": "markup.quote.markdown",
      "settings": {
        "foreground": "#888477",
        "fontStyle": "italic"
      }
    },
    {
      "scope": "meta.separator.markdown",
      "settings": {
        "foreground": "#D4C4A8"
      }
    },
    {
      "scope": [
        "punctuation.definition.raw.markdown",
        "markup.fenced_code.block.markdown"
      ],
      "settings": {
        "foreground": "#888477"
      }
    },

    {
      "name": "Dockerfile - Instructions (FROM, RUN, WORKDIR, etc.)",
      "scope": [
        "keyword.other.special-method.dockerfile",
        "keyword.control.onbuild.dockerfile",
        "keyword.other.special-method.from.dockerfile",
        "keyword.other.special-method.as.dockerfile"
      ],
      "settings": {
        "foreground": "#945EB8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Dockerfile - Image name",
      "scope": [
        "entity.name.image.dockerfile"
      ],
      "settings": {
        "foreground": "#E2931D",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Dockerfile - Image stage alias (AS name)",
      "scope": [
        "entity.name.image.stage.dockerfile"
      ],
      "settings": {
        "foreground": "#E2931D"
      }
    },
    {
      "name": "Dockerfile - Image version/tag (e.g. :1.1)",
      "scope": [
        "constant.numeric.version.dockerfile",
        "constant.constant.language.symbol.digest.dockerfile"
      ],
      "settings": {
        "foreground": "#F76D47"
      }
    },
    {
      "name": "Dockerfile - ARG/ENV variable name definition and $VAR references",
      "scope": [
        "variable.other.dockerfile",
        "punctuation.definition.variable.dockerfile",
        "variable.other.env.dockerfile",
        "variable.other.arg.dockerfile"
      ],
      "settings": {
        "foreground": "#F7A84A"
      }
    },
    {
      "name": "Dockerfile - Strings",
      "scope": [
        "string.quoted.single.dockerfile",
        "string.quoted.double.dockerfile"
      ],
      "settings": {
        "foreground": "#91B859"
      }
    },
    {
      "name": "Dockerfile/Shell - Command name (pip3, apt-get, uv, etc.)",
      "scope": [
        "entity.name.command.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#39ADB5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Dockerfile/Shell - Shell variables ($VAR in RUN/WORKDIR)",
      "scope": [
        "variable.other.normal.shell.dockerfile",
        "variable.other.readwrite.shell.dockerfile",
        "variable.other.bracket.shell.dockerfile",
        "variable.other.special.shell.dockerfile",
        "variable.other.positional.shell.dockerfile",
        "variable.other.assignment.shell.dockerfile",
        "punctuation.definition.variable.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#F7A84A"
      }
    },
    {
      "name": "Dockerfile/Shell - Logical operators (&& ||)",
      "scope": [
        "keyword.operator.logical.shell.dockerfile",
        "punctuation.separator.statement.and.shell.dockerfile",
        "punctuation.separator.statement.or.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#945EB8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Dockerfile/Shell - Command options/flags (-y, --fix-missing)",
      "scope": [
        "constant.other.option.shell.dockerfile",
        "constant.other.option.dash.shell.dockerfile",
        "string.unquoted.argument.shell.dockerfile constant.other.option.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#6182B8"
      }
    },
    {
      "name": "Dockerfile/Shell - Plain arguments (install, scikit-build, package==ver)",
      "scope": [
        "string.unquoted.argument.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#546E7A"
      }
    },
    {
      "name": "Dockerfile/Shell - Double-quoted strings",
      "scope": [
        "string.quoted.double.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#91B859"
      }
    },
    {
      "name": "Dockerfile/Shell - Single-quoted strings",
      "scope": [
        "string.quoted.single.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#91B859"
      }
    },
    {
      "name": "Dockerfile/Shell - URLs (underlined)",
      "scope": [
        "markup.underline.link.shell.dockerfile",
        "string.other.link.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#39ADB5",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Dockerfile/Shell - Comments",
      "scope": [
        "comment.line.number-sign.shell.dockerfile",
        "punctuation.definition.comment.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#888477",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Dockerfile/Shell - Numeric constants",
      "scope": [
        "constant.numeric.integer.shell.dockerfile",
        "constant.numeric.hex.shell.dockerfile",
        "constant.numeric.octal.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#F76D47"
      }
    },
    {
      "name": "Dockerfile/Shell - Boolean constants",
      "scope": [
        "constant.language.true.shell.dockerfile",
        "constant.language.false.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#F76D47"
      }
    },
    {
      "name": "Dockerfile/Shell - Pipe operator",
      "scope": [
        "keyword.operator.pipe.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#945EB8"
      }
    },
    {
      "name": "Dockerfile/Shell - Redirection operators",
      "scope": [
        "keyword.operator.redirect.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#39ADB5"
      }
    },
    {
      "name": "Dockerfile/Shell - Escape characters",
      "scope": [
        "constant.character.escape.shell.dockerfile",
        "constant.character.escaped.dockerfile"
      ],
      "settings": {
        "foreground": "#F76D47"
      }
    },
    {
      "name": "Dockerfile/Shell - Punctuation semicolon",
      "scope": [
        "punctuation.terminator.statement.semicolon.shell.dockerfile"
      ],
      "settings": {
        "foreground": "#39ADB5"
      }
    },
    {
      "name": "Dockerfile - Version separator colon",
      "scope": [
        "punctuation.separator.version.dockerfile"
      ],
      "settings": {
        "foreground": "#888477"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#E2931D",
    "class.defaultLibrary": "#E2931D",
    "type": "#E2931D",
    "type.defaultLibrary": "#E2931D",
    "function": "#6182B8",
    "function.defaultLibrary": {
      "foreground": "#6182B8",
      "fontStyle": "italic"
    },
    "method": "#6182B8",
    "method.defaultLibrary": {
      "foreground": "#6182B8",
      "fontStyle": "italic"
    },
    "parameter": "#F76D47",
    "variable": "#272727",
    "property": "#272727",
    "keyword": {
      "foreground": "#39ADB5",
      "fontStyle": "italic"
    }
  }
}
